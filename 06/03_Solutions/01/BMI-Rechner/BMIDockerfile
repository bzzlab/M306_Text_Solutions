# Use official PHP image with Apache
FROM php:8.2-apache

# Install commonly needed PHP extensions (adjust to your app's needs)
RUN apt-get update && apt-get install -y \
    libzip-dev \
    unzip \
    git \
    && docker-php-ext-install pdo pdo_mysql zip \
    && apt-get clean && rm -rf /var/lib/apt/lists/*

# Enable Apache mod_rewrite (needed for most PHP frameworks/routing)
RUN a2enmod rewrite

# Copy app source code into the container
COPY ./app /var/www/html

# Set working directory to Apache's document root
WORKDIR /var/www/html

# Set correct permissions (adjust if your app writes to specific folders, e.g. storage/, uploads/)
RUN chown -R www-data:www-data /var/www/html

# Expose port 80 (Apache default)
EXPOSE 80

# Apache runs in foreground automatically with this base image
CMD ["apache2-foreground"]
